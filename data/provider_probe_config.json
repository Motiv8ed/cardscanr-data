{
  "schemaVersion": "1.0.0",
  "providers": {
    "pokewallet": {
      "enabled": true,
      "requiresApiKey": true,
      "apiKeyEnv": "POKEWALLET_API_KEY",
      "baseUrl": "https://api.pokewallet.io",
      "probeSearchTerms": [
        "charizard japanese",
        "pikachu japanese",
        "mew japanese",
        "mega symphonia",
        "battle partners",
        "sv10",
        "sv11",
        "ADV1",
        "PMCG1"
      ],
      "maxRequests": 25,
      "requestSleepSeconds": 0.25
    }
  }
}
