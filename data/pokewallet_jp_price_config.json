{
  "schemaVersion": "1.0.0",
  "enabled": true,
  "provider": "pokewallet",
  "apiKeyEnv": "POKEWALLET_API_KEY",
  "mode": "controlled_test",
  "maxRequestsPerRun": 40,
  "requestSleepSeconds": 0.35,
  "targetLanguages": [
    "jp"
  ],
  "targetGame": "pokemon",
  "confidenceThreshold": 0.82,
  "writeOnlyConfidentMatches": true,
  "usePokewalletSetMap": true,
  "setMapMaxSets": 25,
  "searchStrategy": "pokewallet_set_id_plus_card_number",
  "fallbackSearchStrategies": [
    "pokewallet_set_code_plus_card_number",
    "name_plus_pokewallet_set_code"
  ],
  "useCatalogueSampleTargets": true,
  "catalogueSampleLimit": 25,
  "catalogueSampleStrategy": "known_popular_and_recent",
  "cataloguePreferredSetIds": [
    "SV10",
    "SV11B",
    "SV11W",
    "SV9",
    "SV9a",
    "S12a",
    "PMCG1",
    "E1",
    "E2"
  ],
  "catalogueSearchTemplates": [
    "{name} {setName} {collectorNumber} japanese pokemon",
    "{name} {collectorNumber} japanese pokemon",
    "{name} {setName} pokemon card"
  ],
  "searchTargets": [
    {
      "query": "charizard japanese",
      "expectedLanguage": "jp"
    },
    {
      "query": "pikachu japanese",
      "expectedLanguage": "jp"
    },
    {
      "query": "mew japanese",
      "expectedLanguage": "jp"
    },
    {
      "query": "mega symphonia",
      "expectedLanguage": "jp"
    },
    {
      "query": "battle partners",
      "expectedLanguage": "jp"
    },
    {
      "query": "sv10 japanese pokemon",
      "expectedLanguage": "jp"
    },
    {
      "query": "sv11 japanese pokemon",
      "expectedLanguage": "jp"
    },
    {
      "query": "pmcg1 japanese pokemon",
      "expectedLanguage": "jp"
    }
  ]
}
