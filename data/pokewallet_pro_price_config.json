{
  "schemaVersion": "1.0.0",
  "enabled": false,
  "provider": "pokewallet",
  "apiKeyEnv": "POKEWALLET_API_KEY",
  "mode": "pro_probe_foundation",
  "proEndpoint": "/prices/{setCode}",
  "requiresPro": true,
  "maxRequestsPerRun": 25,
  "requestSleepSeconds": 0.35,
  "targetGame": "pokemon",
  "targetLanguages": [
    "eng",
    "jap",
    "kor",
    "chn",
    "zho",
    "chi",
    "chs",
    "cht"
  ],
  "languageMap": {
    "eng": "en",
    "jap": "jp",
    "kor": "kr",
    "ko": "kr",
    "chn": "zh-cn",
    "zho": "zh",
    "chi": "zh",
    "chs": "zh-cn",
    "cht": "zh-tw",
    "zh-cn": "zh-cn",
    "zh-tw": "zh-tw"
  },
  "marketNotes": {
    "tcgplayer": {
      "market": "US",
      "currency": "USD"
    },
    "cardmarket": {
      "market": "EU",
      "currency": "EUR"
    }
  },
  "probeSetLimits": {
    "en": 3,
    "jp": 5,
    "kr": 2,
    "zh-cn": 2,
    "zh-tw": 2
  },
  "preferredProbeSetCodes": {
    "en": [
      "base1",
      "sv1",
      "sv10"
    ],
    "jp": [
      "SV10",
      "SV11B",
      "SV11W",
      "SV9",
      "SV9a"
    ],
    "kr": [],
    "zh-cn": [],
    "zh-tw": []
  },
  "writePriceFiles": false,
  "diagnosticsOnly": true,
  "trialDiscovery": {
    "enabled": false,
    "diagnosticsOnly": true,
    "statePath": "data/pokewallet_pro_trial_discovery_state.json",
    "maxRequestsPerRun": 3000,
    "requestSleepSeconds": 0.2,
    "stopWhenRemainingHourBelow": 200,
    "stopWhenRemainingDayBelow": 1000,
    "includeLanguages": [
      "eng",
      "jap",
      "kor",
      "chn",
      "zho",
      "chi",
      "chs",
      "cht"
    ],
    "preferNumericSetId": true,
    "testPrices": true,
    "testSetStatistics": true,
    "testCompletionValue": true,
    "testTrending": true,
    "testTopCards": true,
    "testPriceHistorySamples": true,
    "testImageSamples": true,
    "imageSampleLimit": 25,
    "priceHistorySampleLimit": 25,
    "sampleRecordLimit": 50,
    "writeRawResponses": false,
    "writeProductionPriceFiles": false,
    "writeImagesToRepo": false
  }
}
